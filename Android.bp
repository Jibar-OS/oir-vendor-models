// v0.6.9: 16 kHz / 16-bit / mono reference WAV for OirDemo's
// audio.transcribe tile. Short (~5s of English speech, PCM, ~720 KB).
// whisper-tiny-en + this WAV gives a runnable audio.transcribe demo
// from a clean cvd boot without manual `adb push` of a voice asset.
prebuilt_etc {
    name: "oir_voice_sample_wav",
    src: "models/voice-sample.wav",
    sub_dir: "oir",
    product_specific: true,
    filename_from_src: true,
}
